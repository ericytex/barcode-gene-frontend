# Frontend Environment Configuration
# Copy this to .env.local for local development

# API Configuration
# For development: http://localhost:8034
# For production: http://194.163.134.129:8034
VITE_API_BASE_URL=http://194.163.134.129:8034
VITE_API_KEY=frontend-api-key-12345

# Development Settings
VITE_DEBUG=true
VITE_LOG_REQUESTS=true

# IMPORTANT: For Vercel Production Deployment
# You MUST set these environment variables in Vercel Dashboard:
# 1. Go to Vercel Dashboard > Your Project > Settings > Environment Variables
# 2. Add these variables for Production environment:
#    - VITE_API_BASE_URL = http://194.163.134.129:8034
#    - VITE_API_KEY = frontend-api-key-12345
#    - VITE_LOG_REQUESTS = true
# 3. Redeploy your project after adding the variables
#
# If you don't set these, the app will use fallback values but may not work correctly.
