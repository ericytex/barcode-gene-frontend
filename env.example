# Frontend Environment Configuration
# Copy this to .env.local and update with your actual API keys

# API Configuration
# For development: http://localhost:8000
# For production: http://194.163.134.129:8000
VITE_API_BASE_URL=http://194.163.134.129:8000
VITE_API_KEY=frontend-api-key-12345

# Development Settings
VITE_DEBUG=true
VITE_LOG_REQUESTS=true

# Production Settings for Vercel Deployment
